{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "requirementsPath": "backend/requirements.txt" }
    },
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
